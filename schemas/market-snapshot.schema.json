{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://org-coin.local/schemas/market-snapshot.schema.json",
  "title": "MarketSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "market",
    "asOf",
    "lastTradePrice",
    "bestBidPrice",
    "bestAskPrice",
    "bestBidSize",
    "bestAskSize",
    "spreadBps",
    "depthRatio",
    "rolling24hNotional"
  ],
  "properties": {
    "market": {
      "type": "string",
      "pattern": "^[A-Z]{3,10}-[A-Z0-9]{2,20}$"
    },
    "asOf": {
      "type": "string",
      "format": "date-time"
    },
    "lastTradePrice": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "bestBidPrice": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "bestAskPrice": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "bestBidSize": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "bestAskSize": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "spreadBps": {
      "type": "number",
      "minimum": 0
    },
    "depthRatio": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "rolling24hNotional": {
      "type": "number",
      "minimum": 0
    }
  }
}
