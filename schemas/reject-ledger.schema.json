{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://org-coin.local/schemas/reject-ledger.schema.json",
  "title": "RejectLedgerSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "totalRejectedDecisions",
    "byMarket",
    "byReason",
    "entries"
  ],
  "properties": {
    "totalRejectedDecisions": {
      "type": "integer",
      "minimum": 0
    },
    "byMarket": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "total",
          "reasons"
        ],
        "properties": {
          "total": {
            "type": "integer",
            "minimum": 0
          },
          "reasons": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "byReason": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "total",
          "markets"
        ],
        "properties": {
          "total": {
            "type": "integer",
            "minimum": 0
          },
          "markets": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decisionId",
          "createdAt",
          "reasonCodes",
          "reasons"
        ],
        "properties": {
          "decisionId": {
            "type": "string"
          },
          "signalId": {
            "type": "string"
          },
          "market": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "reasonCodes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "code",
                "message"
              ],
              "properties": {
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "detail": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
