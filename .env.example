# Future live rollout only. Public-data and paper-mode work in this repo
# should not require exchange credentials.
TRADING_MODE=paper
ENABLE_LIVE_EXECUTION=false
# Live manager also requires this after readiness checks pass and
# LIVE_READINESS_SUMMARY_PATH points to a single-candidate artifact classified
# as live_candidate. BTC 240m time-series readiness additionally requires a
# realized, reconciled, positive-PnL reduce-only paper exit.
LIVE_READINESS_APPROVED=false
LIVE_READINESS_SUMMARY_PATH=
# Live readiness artifacts must be fresh; PM2 start scripts refresh them before
# startup. Default is 15 minutes.
LIVE_READINESS_MAX_AGE_MS=900000
# Live mode also requires confirming the active account fee schedule. Keep this
# false until the Bithumb account's current KRW-BTC bid/ask fee has been checked.
LIVE_TRADING_FEE_SCHEDULE_CONFIRMED=false
# Round-trip fee in basis points for the active account fee schedule. The live
# startup gate rejects values above the readiness benchmark fee assumption.
LIVE_TRADING_FEE_ROUND_TRIP_BPS=

# Public endpoint defaults.
BITHUMB_REST_BASE_URL=https://api.bithumb.com/v1
BITHUMB_WS_BASE_URL=wss://ws-api.bithumb.com/websocket/v1

# Do not commit real values.
BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=
BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_FUTURES_REST_BASE_URL=https://fapi.binance.com
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Cross-exchange live path requires both flags, a fresh live-readiness artifact,
# and a clean operational proof. Submission remains disabled unless explicitly
# enabled for a one-shot run.
ENABLE_CROSS_EXCHANGE_LIVE_EXECUTION=false
ENABLE_CROSS_EXCHANGE_ORDER_SUBMISSION=false

# Operational safety rails for the paper-session runner.
MAX_DAILY_LOSS_KRW=500000
MAX_ORDER_NOTIONAL_KRW=1000000
# Set a positive value to override all per-market paper caps with one global cap.
# Keep 0 to use the built-in per-market defaults from src/execution/order-manager.ts.
MAX_POSITION_NOTIONAL_KRW=0
# Optional JSON object for market-specific cap overrides.
# Example: {"KRW-BTC":1900000,"KRW-ETH":1500000}
MAX_POSITION_NOTIONAL_BY_MARKET_JSON=
DATA_STALE_AFTER_MS=5000
KILL_SWITCH_REJECT_STREAK=3

# Paper-session evidence artifacts. Defaults to var/paper-sessions under the repo root.
PAPER_SESSION_ARTIFACTS_DIR=var/paper-sessions

# Managed dry_run service inputs for the pm2 loop runner.
DRY_RUN_BASE_DIR=var/data
DRY_RUN_EXECUTION_MODE=paper
# v1, exploratory_smoke, or explicit experiment btc_trend_v1.
DRY_RUN_ENTRY_PROFILE=v1
# core_safe, balanced_v1, balanced_v1_book_confirm2,
# balanced_v1_book_confirm3, balanced_v1_book_confirm3_trend_hold,
# balanced_v1_book_confirm3_trend_hold_guarded, or experimental_decay.
# Trend-hold variants are paper-only until benchmark evidence passes.
DRY_RUN_EXIT_PROFILE=balanced_v1_book_confirm3
DRY_RUN_SYNTHETIC_EXIT_POLICY=carry_open
DRY_RUN_INITIAL_CASH_KRW=1000000
DRY_RUN_LOOP_INTERVAL_SECONDS=300
DRY_RUN_LOG_DIR=var/log/dry-run-btc-confirm3-service
DRY_RUN_CYCLE_LOG_FILE=cycles.ndjson
# Leave blank to auto-detect .venv/bin/python and otherwise fall back to python3.
DRY_RUN_PYTHON_BIN=
DRY_RUN_MARKETS=KRW-BTC
DRY_RUN_FRESHNESS_SLA_MS=10000
DRY_RUN_CANDLE_COUNT=180
DRY_RUN_TRADE_COUNT=200
DRY_RUN_WS_SECONDS=15
DRY_RUN_TRADE_WARMUP_SECONDS=60
DRY_RUN_BOOTSTRAP_ITERATIONS=1
DRY_RUN_BOOTSTRAP_INTERVAL_SECONDS=0
DRY_RUN_WS_CHANNELS=ticker,trade,orderbook
